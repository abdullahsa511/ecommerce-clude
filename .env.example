# Application environment: development shows detailed JSON errors; production redirects to error pages.
ENVIRONMENT=development

# --- Mail (Symfony Mailer) ---
# Google Workspace: Admin configures SMTP relay; use host/port from Google (often smtp-relay.gmail.com:587 with TLS).
# IP-based relay often needs no username/password:
# MAILER_DSN=smtp://smtp-relay.gmail.com:587
# Authenticated relay (example — get exact DSN from your admin):
# MAILER_DSN=smtp://relay-user:secret@smtp-relay.gmail.com:587
#
# --- Local fake inbox (Mailpit): docker compose up -d mailpit → http://localhost:8025
# PHP on your machine (not in Docker):
# MAILER_DSN=smtp://127.0.0.1:1025
# PHP inside mvc.php container (same compose network):
# MAILER_DSN=smtp://mailpit:1025
#
# Mailtrap (hosted): use the SMTP user/pass/host/port from your Mailtrap inbox, e.g.
# MAILER_DSN=smtp://USERNAME:PASSWORD@sandbox.smtp.mailtrap.io:2525
#
# Local development without sending:
# MAILER_DSN=null://null
MAILER_DSN=null://null

# Envelope From must be allowed by your Workspace relay rules (e.g. @your-verified-domain).
# For Mailpit local testing, any plausible address is fine (e.g. noreply@example.test).
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# --- Google reCAPTCHA v3 (contact form) ---
# Create keys at https://www.google.com/recaptcha/admin — choose "reCAPTCHA v3".
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Scores below this threshold are rejected (0.0 = bot, 1.0 = human). Default 0.5.
RECAPTCHA_MIN_SCORE=0.5
# grecaptcha.execute() action names — shown separately in reCAPTCHA Admin analytics.
RECAPTCHA_ACTION=contact_submit
RECAPTCHA_ACTION_SERVICE=service_request
RECAPTCHA_ACTION_PROJECT=project_submission
RECAPTCHA_ACTION_BOOKING=showroom_booking
RECAPTCHA_ACTION_CATALOGUE=catalogue_request

# --- Instagram Graph API (admin product Instagram linking) ---
# Create a Meta app: https://developers.facebook.com/
# Connect an Instagram Business/Creator account to a Facebook Page.
#
# Production token flow (recommended):
# 1. Generate a short-lived user token in Graph API Explorer
# 2. Run: php src/Core/commands/instagram-page-token.php --token=SHORT_LIVED_TOKEN
#    Or list pages first: php src/Core/commands/instagram-page-token.php --list-pages --token=SHORT_LIVED_TOKEN
# 3. Copy the printed page access token + business account id into .env below
#
# API alternative:
# POST /api/instagram/token/page-credentials  { "short_lived_token": "...", "page_id": "optional" }
INSTAGRAM_GRAPH_API_VERSION=v21.0
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_PAGE_ID=
# Optional: only used by instagram-page-token.php CLI helper
INSTAGRAM_SHORT_LIVED_TOKEN=
# Set true for local admin UI development without Meta credentials (returns mock hashtag/posts).
INSTAGRAM_MOCK=false
