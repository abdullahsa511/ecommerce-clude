<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject|default('Internal Notification - New Showroom Booking') }}</title>
</head>
<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f3f4f6; padding:24px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px; background-color:#ffffff; border:1px solid #e5e7eb; border-radius:8px;">
          <tr>
            <td style="padding:20px 24px 0px 24px; color: #374151;">
              <p style="margin:0 0 20px 0;">Email Subject: <strong>{{ subject|default('Internal Notification - New Showroom Booking') }}</strong></p>
            </td>
          </tr>

          <tr>
            <td style="padding:0px 24px 0 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 20px 0;">Hi {{ recipient_name|default('Krost Sales') }},</p>
              <p style="margin:0 0 0px 0;">
                  Your have a new showroom tour booked. Please review the details below and ensure this is added to the Google Calendar.
              </p>
            </td>
          </tr>

          <tr>
            <td style="padding:0px 24px 0 8px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding:20px 16px 5px 16px;">
                    <p style="margin:0; font-size:16px; font-weight:bold; color:#374151;">Meeting Details:</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:0px 16px 20px 24px; font-size:16px; line-height:1.7; color: #374151;">
                    <ul style="margin:0; padding-left:22px;">
                      <li><strong>Date:</strong> {{ meeting_date|default('[Date]') }}</li>
                      <li><strong>Time:</strong> {{ meeting_time|default('[9:00 - 9:30am]') }} [{{ time_zone|default('AEST (GMT+10:00) Time in Sydney NSW') }}]</li>
                      <li><strong>Location:</strong><a href="{{ google_map_link|default('#') }}"> {{ location|default('[Showroom Address]') }}</a></li>
                      <li><strong>Client Email:</strong> {{ client_email|default("[Client's Email]") }}</li>
                    </ul>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="padding:18px 24px 0 24px; font-size:16px; line-height:1.6; color:#374151;">
              {# <p style="margin:0 0 20px 0;">If you need to Reschedule or Cancel this meeting, please contact the client's email directly and Cancel directly via your Google Calendar.</p> #}
                <p style="margin:0 0 20px 0;">
                  Click the <span style="font-weight:bold;">Calendar</span> button to add the customer showroom visit event to the calendar
                  {% if pinboard_id is defined and pinboard_id %}
                  , or use the <span style="font-weight:bold;">Create Lead</span> button to convert the pinboard directly into a lead in Kingmaker. 
                  {% endif %}
                  Please remember to update the calendar event name to include the client or company details.
                </p>
            </td>
          </tr>
          <tr>
            <td style="padding:12px 24px 24px 24px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="left" style="padding-right:12px;">
                    <a href="{{ booking_link|default('#') }}"
                       style="background:#255793; color:#ffffff; padding:12px 24px; text-decoration:none; border-radius:6px; display:inline-block; font-size:16px; line-height:1.2; font-family:Arial, Helvetica, sans-serif;">
                      Calendar
                    </a>
                  </td>
                  <td align="left">
                    <a href="{{ admin_url|default('#') }}"
                       style="background:#255793; color:#ffffff; padding:12px 24px; text-decoration:none; border-radius:6px; display:inline-block; font-size:16px; line-height:1.2; font-family:Arial, Helvetica, sans-serif;">
                      Create Lead
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="padding:24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 6px 0;">Best regards,</p>
              <p style="margin:0;"><strong>Krost Website Booking System</strong></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
