<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Booking Cancelled: Showroom Tour with Krost</title>
</head>

<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6; padding:24px 12px;">
<tr>
<td align="center">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:970px; background:#ffffff; border:1px solid #e5e7eb; border-radius:8px;">
  <!-- Body -->
  <tr>
    <td style="padding:24px 24px 0px 24px; font-size:16px; line-height:16x; color:#374151;">

      <p style="margin:0 0 20px 0; line-height:16x;">
        Hi <strong>{{ client_name|default('Valued Customer') }}</strong>,
      </p>

      <p style="margin:0 0 20px 0; line-height:16x;">
        This email confirms that your appointment for a 
        <strong>Krost Showroom Tour</strong> on 
        <strong>{{ date|default('') }}</strong> 
        has been successfully cancelled.
      </p>

      <p style="margin:0 0 0px 0; line-height:16x;">
        If your plans have changed and you would like to visit us at a different time, 
        please feel free to select a new slot via the link below:
      </p>

    </td>
  </tr>

  <!-- CTA Button -->
  <tr>
    <td align="left" style="padding:20px 24px 20px 24px; font-size:16px; line-height:16x; color:#374151;">
      <a href="{{ reschedule_url|default('#') }}" target="_blank"
         style="background:#255793; color:#ffffff; padding:12px 24px; text-decoration:none; border-radius:6px; display:inline-block; line-height:16x;">
        Reschedule a New Appointment
      </a>
    </td>
  </tr>

  <!-- Footer -->
  <tr>
    <td style="padding:0px 24px 0px 24px; font-size:16px; line-height:16x; color:#374151;">

      <p style="margin:0 0 20px 0; line-height:16x;">
        We hope to see you in the showroom soon.
      </p>

      <p style="margin:0 0 20px 0; line-height:16x;">
        Best regards,
      </p>
      <p style="margin:0 0 20px 0; line-height:16x;">
        <strong>Krost Business Furniture</strong>
      </p>

    </td>
  </tr>

</table>

</td>
</tr>
</table>

</body>
</html>