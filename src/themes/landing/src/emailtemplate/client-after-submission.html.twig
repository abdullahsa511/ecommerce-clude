<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject|default("We've received your project! – [Project Name]") }}</title>
</head>
<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f3f4f6; padding:24px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px; background-color:#ffffff; border:1px solid #e5e7eb; border-radius:8px;">
          <tr>
            <td style="padding:0px 24px 10px 24px;">
              <p style="margin:0 0 20px 0;">Subject: <strong>{{ subject|default("We've received your project! – [Project Name]") }}</strong></p>
            </td>
          </tr>

          <tr>
            <td style="padding:30px 24px 0 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 20px 0;">Hi {{ client_name|default('[Client Name]') }},</p>
              <p style="margin:0 0 20px 0;">Thank you for sharing your project pinboard with us! </p>
            </td>
          </tr>
          <tr>
            <td style="padding:0px 24px 0 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 20px 0;">One of our specialists will be in touch shortly to discuss your ideas and help bring your space to life.</p>
            </td>
          </tr>

          <tr>
            <td style="padding:10px 24px 0 8px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding:0px 16px 20px 24px; font-size:16px; line-height:1.7;">
                    <ul style="margin:0; padding-left:22px;">
                      <li>Project Name: {{ project_name|default('') }}</li>
                      <li>Items Saved: {{ items_saved|default('') }}</li>
                      <li>Submission Date: {{ submission_date|default('') }}</li>
                    </ul>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="padding:18px 24px 0 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 20px 0;">In the meantime, feel free to explore <a href="{{ collections_url|default('#') }}" style="color:#0097a7; text-decoration:underline;">our latest collections</a>.</p>
            </td>
          </tr>

          <tr>
            <td style="padding:18px 24px 0 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 20px 0;">We look forward to working with you!</p>
            </td>
          </tr>

          <tr>
            <td style="padding:24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 6px 0;">Best regards,</p>
              <p style="margin:0;"><strong>The Krost Team.</strong></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
