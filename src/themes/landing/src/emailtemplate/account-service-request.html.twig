<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ subject|default('Krost Website | Service Request Received') }}</title>
</head>

<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">

{% set attachment_labels = attachment_labels|default([]) %}

<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f3f4f6; padding:24px 12px;">
    <tr>
        <td align="center">

        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:970px; background-color:#ffffff; border:1px solid #e5e7eb; border-radius:8px;">

            <tr>
                <td style="padding:24px 24px 0 24px; font-size:16px; line-height:1.4; color:#374151;">
                    <p style="margin:0 0 20px 0;">
                        Hi,
                    </p>

                    <p style="margin:0 0 20px 0;">
                        Thank you for submitting a service request for <strong>{{ order_number|default('#1') }}</strong>. Our customer service team will be in contact shortly.
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding:0 24px; font-size:16px; color:#374151;">
                    <p style="margin:0 0 5px 0; font-size:16px; font-weight:bold;">
                        Your Service Request Summary:
                    </p>

                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                        <tr>
                            <td style="padding:0 24px; font-size:16px; line-height:1.7;">
                                <ul style="margin:0; padding-left:10px;">
                                    <li style="line-height:1.7;">
                                        <strong>Order Number:</strong>
                                        {{ order_number|default('#1') }}
                                    </li>

                                    <li style="line-height:1.7;">
                                        <strong>Issue Description:</strong>
                                        {{ issue_description|default('#3') }}
                                    </li>

                                    <li style="line-height:1.7;">
                                        <strong>Attachments:</strong>
                                        {{ attachment_labels|length ? attachment_labels|join(', ') : 'none' }}
                                    </li>
                                </ul>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>

            <tr>
                <td style="padding:20px 24px 0 24px; font-size:16px; line-height:1.6; color:#374151;">
                    <p style="margin:0 0 20px 0; line-height:1.7;">
                        If you have any additional questions, don't hesitate to reply to this email or contact us.
                    </p>
                </td>
            </tr>
            <tr>
                <td style="padding:0 24px 20px 24px; font-size:16px; line-height:1.4; color:#374151;">
                    <p style="margin:0 0 20px 0;">Best Regards,</p>
                    <p style="margin:0;"><strong>The Krost Team</strong></p>
                </td>
            </tr>

        </table>

    </td>
</tr>
</table>

</body>
</html>
