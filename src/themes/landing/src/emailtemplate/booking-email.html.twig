<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject|default('Project details submitted') }}</title>
</head>
<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f3f4f6; padding:24px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:970px; background-color:#ffffff; border:1px solid #e5e7eb; border-radius:8px;">
          <tr>
            <td style="padding:20px 24px 0px 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 20px 0; line-height:1.6;">Hi {{ team_name|default('Sales Team') }},</p>
              <p style="margin:0 0 20px 0; line-height:1.6;">A client has just submitted their Project details via the website for review. Please find the project brief summary below.</p>
            </td>
          </tr>

          <tr>
            <td style="padding:0px 24px 0 24px; font-size:16px; line-height:1.6; color:#374151;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding:0px 0px 8px 0px;">
                    <p style="margin:0; font-size:16px; font-weight:bold; line-height:1.6; color:#374151;">Project Summary Details:</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:0px 24px 0px 24px; font-size:16px; line-height:1.7;">
                    <ul style="margin:0; padding-left:10px;">
                      <li style="line-height:1.7;"><strong>Client Email:</strong> {{ client_email|default("[Client's email]") }}</li>
                      <li style="line-height:1.7;"><strong>Project Name:</strong> {{ project_name|default('[Dynamic Project Name]') }}</li>
                      <li style="line-height:1.7;"><strong>Items:</strong> {{ items_count|default('0') }} items</li>
                      <li style="line-height:1.7;"><strong>Estimated Value:</strong> {{ estimated_value|default('$X,XXX.XX') }}</li>
                    </ul>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="padding:20px 24px 0px 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 8px 0; font-size:16px; font-weight:bold; line-height:1.6;">Additional Client Notes:</p>
              <p style="margin:0 0 20px 0; line-height:1.7;">"{{ client_notes|default('None provided') }}"</p>
            </td>
          </tr>

          <tr>
            <td style="padding:0px 24px 0px 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 8px 0; font-size:16px; font-weight:bold; line-height:1.6;">Attachments:</p>
              {% if attachment_links is defined and attachment_links is iterable and attachment_links|length > 0 %}
                <ul style="margin:0 0 20px 0; padding-left:20px; line-height:1.7;">
                  {% for file_link in attachment_links %}
                    <li style="margin-bottom:6px;">
                      <a href="{{ file_link }}" download target="_blank" rel="noopener noreferrer" style="color:#2563eb; text-decoration:underline;">Link to download File {{ loop.index }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% elseif attachment_link is defined and attachment_link and attachment_label is defined %}
                <ul style="margin:0 0 20px 0; padding-left:20px; line-height:1.7;">
                  <li>
                    <a href="{{ attachment_link }}" download target="_blank" rel="noopener noreferrer" style="color:#2563eb; text-decoration:underline;">{{ attachment_label|default('Link to download File 1') }}</a>
                  </li>
                </ul>
              {% elseif attachments is defined and attachments %}
                <p style="margin:0 0 20px 0; line-height:1.7;">{{ attachments }}</p>
              {% else %}
                <p style="margin:0 0 20px 0; line-height:1.7;">None provided</p>
              {% endif %}
            </td>
          </tr>

          <tr>
            <td style="padding:0px 24px 0px 24px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 20px 0; line-height:1.6;">Regards,</p>
              <p style="margin:0 0 20px 0; line-height:1.6;"><strong>Krost Website Booking System</strong></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
