<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject|default('Confirmed: Your Showroom Tour with Krost') }}</title>
</head>
<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f3f4f6; padding:24px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:970px; background-color:#ffffff; border:1px solid #e5e7eb; border-radius:8px;">
          <tr>
            <td style="padding:24px 24px 0px 24px; font-size:16px; line-height:16x; color:#374151;">
              <p style="margin:0 0 20px 0; line-height:16x;">Hi <strong>{{ client_name|default('[Client Name]') }}</strong>,</p>
              <p style="margin:0 0 0px 0; line-height:16x;">Thank you for booking a showroom tour with us! We have successfully reserved your session, and we look forward to meeting you soon.</p>
            </td>
          </tr>

          <tr>
            <td style="padding:0px 24px 0 24px; font-size:16px; line-height:16x; color:#374151;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding:20px 16px 5px 0px;">
                    <p style="margin:0; font-size:16px; font-weight:bold; color:#374151;">Meeting Details:</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:0px 16px 20px 24px; font-size:16px; line-height:1.7; color: #374151;">
                    <ul style="margin:0; padding-left:22px;">
                      <li style="line-height:1.7"><strong>Date:</strong> {{ meeting_date|default('[Date]') }}</li>
                      <li style="line-height:1.7"><strong>Time:</strong> {{ meeting_time|default('[9:00 - 9:30am]') }} [{{ time_zone|default('AEST (GMT+10:00) Time in Sydney NSW') }}]</li>
                      <li style="line-height:1.7"><strong>Location:</strong><a href="{{ google_map_link|default('#') }}"> {{ location|default('[Showroom Address]') }}</a></li>
                    </ul>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:0px 24px 0px 24px; font-size:16px; line-height:16x; color:#374151;">
              <p style="margin:0 0 20px 0; line-height:16x;">We have attached a calendar invitation to this email so you can easily add this to your schedule.</p>
              <p style="margin:0 0 0px 0; line-height:16x;">If you have specific projects to discuss, feel free to reply to this email or if you need to make changes, you can <a href="{{ reschedule_url|default('#') }}" style="color:#255793; font-weight:bold; text-decoration:underline;">Reschedule </a> or <a href="{{ cancel_url|default('#') }}" style="color:#255793; font-weight:bold; text-decoration:underline;"> Cancel your booking</a> here.</p>
       
            </td>
          </tr>

          <tr>
            <td style="padding:20px 24px 0px 24px; font-size:16px; line-height:16x; color:#374151;">
              <p style="margin:0 0 20px 0; line-height:16x;">Best regards,</p>
              <p style="margin:0 0 20px 0; line-height:16x;"><strong>{{ salesperson_name|default('[Salesperson Name]') }}</strong></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
