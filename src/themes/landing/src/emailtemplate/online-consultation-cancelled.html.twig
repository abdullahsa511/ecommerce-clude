<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Online Consultation Cancelled - Krost</title>
</head>

<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6; padding:24px;">
<tr>
<td align="center">

<table role="presentation" width="600" style="background:#fff; border:1px solid #e5e7eb; border-radius:8px;">

  <!-- Header -->
  <tr>
    <td style="padding:20px 24px 0px;">
      <p style="margin:0;">
        Email Subject: 
        <strong>Booking Cancelled: Online Consultation with Krost</strong>
      </p>
    </td>
  </tr>

  <!-- Body -->
  <tr>
    <td style="padding: 20px 24px 20px 24px; font-size:16px; line-height:1.6; color:#374151;">

      <p style="margin:0; padding: 0px 0 0 0px;">Hi <strong>{{ client_name }}</strong>,</p>

      <p style="margin:0; padding: 20px 0 0 0px;">
        This email confirms that your appointment for 
        <strong>Online Consultation</strong> on 
        <strong>{{ date }}</strong> has been successfully cancelled.
      </p>

      <p style="margin:0; padding: 20px 0 0 0px;">
        If your plans have changed and you would like to reach out to us at a different time, 
        please feel free to select a new slot via the link below:
      </p>

    </td>
  </tr>

  <!-- CTA -->
  <tr>
    <td align="center" style="padding:0px;">
      <a href="{{ reschedule_link }}"
         style="background:#255793; color:#fff; padding:12px 24px; text-decoration:none; border-radius:6px; display:inline-block;">
        Reschedule a New Appointment
      </a>
    </td>
  </tr>

  <!-- Footer -->
  <tr>
    <td style="padding:20px 24px 24px; font-size:16px; line-height:1.6; color:#374151;">

      <p style="margin:0; padding: 0 0 20px 0;">
        We hope to connect with you soon.
      </p>

      <p style="margin:0; padding: 0px 0 0 0px;">
        Best regards,<br>
        <strong>The Krost Team</strong><br>
        Krost Business Furniture
      </p>

    </td>
  </tr>

</table>

</td>
</tr>
</table>

</body>
</html>