<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Booking Verification Code with Krost</title>
</head>

<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">

<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f3f4f6; padding:24px 12px;">
<tr>
<td align="center">

<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:970px; background-color:#ffffff; border:1px solid #e5e7eb; border-radius:8px;">
  <!-- Body -->
  <tr>
    <td style="padding:24px 24px 0px 24px; font-size:16px; line-height:1.7; color:#374151;">
      <p style="margin:0 0 20px 0;">
        Hi <strong>{{ client_name|default('Valued Customer') }}</strong>,
      </p>

      <p style="margin:0 0 0px 0;">
        Your verification code for your booking with Krost is:
      </p>
    </td>
  </tr>

  <!-- OTP Box -->
  <tr>
    <td align="center" style="padding:20px 24px;">
      <table role="presentation" cellspacing="0" cellpadding="0">
        <tr>

          {# Convert OTP string into array of digits #}
          {% set digits = otp|default('123456')|split('') %}

          {% for digit in digits %}
            <td style="border:1px solid #e5e7eb; padding:12px 16px; font-size:20px; font-weight:bold; color:#374151;">
              {{ digit }}
            </td>

            {% if not loop.last %}
              <td style="width:6px;"></td>
            {% endif %}
          {% endfor %}

        </tr>
      </table>
    </td>
  </tr>

  <!-- Instructions -->
  <tr>
    <td style="padding:0px 24px 0px 24px; font-size:16px; line-height:1.7; color:#374151;">
      <p style="margin:0 0 20px 0;">
        Please enter this code back on our website to finalise your booking.
      </p>

      <p style="margin:0 0 20px 0;">
        This code will expire in <strong>{{ expiry_minutes|default(10) }} minutes</strong>.
      </p>
    </td>
  </tr>

  <!-- Footer -->
  <tr>
    <td style="padding:0px 24px 0px 24px; font-size:16px; line-height:1.7; color:#374151;">
      <p style="margin:0 0 20px 0;">Best regards,</p>
      <p style="margin:0 0 20px 0;"><strong>Krost Business Furniture</strong></p>
    </td>
  </tr>

</table>

</td>
</tr>
</table>

</body>
</html>