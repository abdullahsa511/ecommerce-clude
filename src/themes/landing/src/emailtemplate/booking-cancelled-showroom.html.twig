<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Booking Cancelled - Krost Showroom Tour</title>
</head>

<body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#374151;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6; padding:24px;">
<tr>
<td align="center">

<table role="presentation" width="600" style="background:#fff; border:1px solid #e5e7eb; border-radius:8px;">

  <!-- Header -->
  <tr>
    <td style="padding:20px 24px 0px 24px;">
      <p style="margin:0 0 20px 0;> Email Subject: <strong>Booking Cancelled: Krost Showroom Tour</strong>
      </p>
    </td>
  </tr>

  <!-- Body -->
  <tr>
    <td style="padding:0px 24px 30px 24px; font-size:16px; line-height:1.6; color:#374151;">

      <p>Hi <strong>{{ client_name }}</strong>,</p>

      <p>
        This email confirms that your appointment for a 
        <strong>Krost Showroom Tour</strong> on 
        <strong>{{ date }}</strong> has been successfully cancelled.
      </p>

      <p>
        If your plans have changed and you would like to visit us at a different time, 
        please feel free to select a new slot via the link below:
      </p>

    </td>
  </tr>

  <!-- CTA -->
  <tr>
    <td align="center" style="padding:20px;">
      <a href="{{ reschedule_link }}"
         style="background:#255793; color:#fff; padding:12px 24px; text-decoration:none; border-radius:6px; display:inline-block;">
        Reschedule a New Appointment
      </a>
    </td>
  </tr>

  <!-- Footer text -->
  <tr>
    <td style="padding:0 24px 24px; font-size:16px; line-height:1.6; color:#374151;">
      <p>
        We hope to see you in the showroom soon.
      </p>

      <p style="margin-top:20px;">
        Best regards,<br>
        <strong>Krost Business Furniture</strong>
      </p>
    </td>
  </tr>

</table>

</td>
</tr>
</table>

</body>
</html>