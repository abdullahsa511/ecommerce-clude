<!DOCTYPE html>
<html lang="en">

<head data-v-component-head>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta charset="utf-8">

  <!-- Preconnect to CDN origins used by footer scripts (saves DNS + TCP + TLS before first request) -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="preconnect" href="https://unpkg.com" crossorigin>
  <link rel="icon" type="image/x-icon" href="../../images/icons/Krost.ico" data-v-global-site.favicon="">
  <link rel="canonical" href="{{ canonical }}" data-v-head-canonical="">
  <base href="">

  <title data-v-head-title>{{ title }}</title>

  <meta name="title" content="{{ metaData.meta_title }}" data-v-head-meta-title="">
  <meta name="description" content="{{ metaData.meta_description }}" data-v-head-meta-description="">
  <meta name="keywords" content="{{ metaData.meta_keywords }}" data-v-head-meta-keywords="">
  <meta name="author" content="Krost Business Furniture" data-v-head-meta-author="">

  <meta property="og:type" content="{{ type }}" data-v-og-type="">
  <meta property="og:title" content="{{ metaData.meta_title }}" data-v-og-title="">
  <meta property="og:description" content="{{ metaData.meta_description }}" data-v-og-description="">
  <meta property="og:url" content="{{ url }}" data-v-og-url="">
  <meta property="og:image" content="{{ og_image }}" data-v-og-image="">
  <meta property="og:site_name" content="Krost Business Furniture">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ metaData.meta_title }}" data-v-twitter-title="">
  <meta name="twitter:description" content="{{ metaData.meta_description }}" data-v-twitter-description="">
  <meta name="twitter:image" content="{{ og_image }}" data-v-twitter-image="">
  <meta name="robots" content="noindex, nofollow">
  <script id="product-schema" type="application/ld+json">
      {{ product_schema|raw }}
  </script>

  <!-- Minimal critical CSS: above-the-fold basics so first paint isn't unstyled -->
  <style>
    html {
      box-sizing: border-box;
      scroll-behavior: smooth
    }

    *,
    *::before,
    *::after {
      box-sizing: inherit
    }

    body {
      margin: 0;
      font-family: "Open Sans", sans-serif;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased
    }
  </style>
  <!-- LCP: preload hero image so it's discoverable from initial document -->
  <!-- <link rel="preload" fetchpriority="high" as="image" href="/img/bg/home/hero_home.jpg"> -->
  <!-- Critical fonts: preload so they start early and don't wait for CSS (shortens chain) -->
  <link rel="preload" href="/fonts/opensans/OpenSans-Regular.ttf" as="font" type="font/ttf" crossorigin>
  <link rel="preload" href="/webfonts/fa-solid-900.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="alternate" type="application/rss+xml" title="Feed" href="/feed/posts" />
  <link rel="alternate" type="application/rss+xml" title="Comments Feed" href="/feed/comments" />

  <!-- Main stylesheet: non-blocking to avoid delaying LCP/FCP -->
  <link rel="preload" href="/css/lib/swiper-bundle.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="stylesheet" href="/css/stylesheet.min.css">
  <link rel="stylesheet" href="/css/solid.min.css">


  <link rel="preload" href="/css/lib/choices.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="/css/lib/flatpickr.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="/css/lib/lightgallery-bundle.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="/css/lib/lg-transitions.css" as="style" onload="this.onload=null;this.rel='stylesheet'">

  <style>
    .booking-calendar-wrapper {
      width: 100%;
      padding: 0 60px;

      @include respond-to(mds) {
        padding: 70px 0;
      }
    }

    .flatpickr-calendar.open,
    .flatpickr-calendar.inline {
      max-height: 100%;
      width: 100%;
      background: none;
      -webkit-box-shadow: none;
      box-shadow: none;
    }

    .flatpickr-months {
      width: 100%;
      justify-content: center;
      padding-bottom: 45px;

      .flatpickr-prev-month.flatpickr-prev-month,
      .flatpickr-prev-month,
      .flatpickr-prev-month.flatpickr-next-month,
      .flatpickr-next-month {
        position: relative;
        left: inherit;
      }

      .flatpickr-month {
        -webkit-box-flex: inherit;
        -webkit-flex: inherit;
        -ms-flex: inherit;
        flex: inherit;
        align-items: center;

        .flatpickr-current-month {
          display: flex;
          text-align: center;
          width: 250px;
          position: relative;
        }
      }
    }

    .flatpickr-rContainer {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    .flatpickr-days {
      width: 100%;
    }

    .dayContainer {
      width: 100%;
      max-width: 100%;
      min-width: 100%;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
    }

    .flatpickr-day {
      margin: 0;
      text-align: center;
      -webkit-box-flex: 1;
      -webkit-flex: 1;
      -ms-flex: 1;
      flex: 1;
      font-weight: bolder;
      width: 100%;
      max-width: inherit;
      max-height: inherit;
      border-radius: 0;
      height: 60px;
      display: flex;
      align-items: center;
    }
  </style>

</head>

<body class="bg-white">
  <style>
    .th-pinboard-count-badge {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      top: -5px;
      right: -10px;
      background-color: rgb(0, 0, 0);
      opacity: 0.8;
      color: #fff;
      border-radius: 50%;
      padding: 2px 5px;
      font-size: 13px;
      line-height: 12px;
      font-weight: 700;
    }

    .th-pinboard-count-badge-text {
      position: relative;
      left: -2px;
    }

    /* User dropdown - shows on click of user icon */
    .th-user-dropdown {
      position: relative;
    }

    .th-user-dropdown .dropdown-toggle {
      color: inherit;
      text-decoration: none;
      padding: 0;
      border: none;
      background: transparent;
      cursor: pointer;
      transition: opacity 0.2s ease;
    }

    .th-user-dropdown .dropdown-toggle:hover {
      opacity: 0.85;
    }

    .th-user-dropdown .dropdown-toggle::after {
      display: none;
      /* Hide default Bootstrap caret - icon is enough */
    }

    .th-user-dropdown .dropdown-menu {
      min-width: 180px;
      padding: 0px 0px;
      margin-top: 10px;
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 8px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }

    .th-user-dropdown .dropdown-item {
      padding: 10px 16px;
      font-size: 15px;
      font-weight: 500;
      color: #2E2E2E;
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .th-user-dropdown .dropdown-item:hover {
      background-color: rgba(0, 0, 0, 0.04);
      color: #231F20;
    }

    .th-user-dropdown .dropdown-divider {
      margin: 6px 0;
    }

    .th-user-dropdown .dropdown-item#logout-button {
      color: #6B7280;
    }

    .th-user-dropdown .dropdown-item#logout-button:hover {
      color: #DC2626;
      background-color: rgba(220, 38, 38, 0.06);
    }
    .th-footer-navigation li {
        padding-left: 20px !important; 
    }
  </style>
  {% include '_navigation.html.twig' %}


  <!--============================== Start Login Page ==============================-->
  <section id="login-page" class="th-login pt-0" data-v-component-login>
    <div class="container th-container">
      <div class="row align-items-center">
        <div class="col-md-6">
          <div class="th-img-container">
            <img src="/media/login/login.png" alt="" data-v-login-image>
          </div>
        </div>
        <div class="col-md-6">
          <div class="th-login-form-container pt-100 w-100">
            <div class="th-login-form-header">
              <h2>Access your Portal</h2>
            </div>
            <div class="th-login-form-body">
              <form class="th-form needs-validation was-validated" id="login-form" action="/login" method="POST">
                <input type="hidden" name="nonce" value="{{ nonce|default('') }}" data-v-nonce>
                <input type="hidden" name="email" id="signup-email-value" data-v-login-email-value>
                <div class="form-group ">
                  <!-- <label data-v-login-email_input_label for="email" class="form-label">Enter Your Email*</label> -->
                  <input type="email" class="form-control" id="email" name="email" placeholder="Enter your Email*" value="{{ data.email|default('') }}" data-v-login-email required>
                  <div class="invalid-feedback" id="email-feedback"></div>
                </div>
                {% if error is defined and error %}
                <div class="invalid-feedback d-block text-left mb-2">{{ error }}</div>
                {% endif %}
                {% if errors is defined and errors %}
                {% for key, err in errors %}
                <div class="invalid-feedback d-block text-left mb-2">{{ err }}</div>
                {% endfor %}
                {% endif %}
                {% if message is defined and message %}
                <div class="valid-feedback d-block text-left mb-2">{{ message }}</div>
                {% endif %}

                <!-- <div class="form-group">
                                    <label data-v-login-email_input_label for="email">Email*</label>
                                    <input type="email" id="email" class="form-control" placeholder="Email*" data-v-login-email required>
                                    <div class="invalid-feedback" id="email-feedback"></div>
                                </div> -->


                <div class="th-pt-20">
                  <button type="submit" id="send-otp-button" class="th-btn-primary w-100 text-capitalize">
                    <span id="send-otp-text">Send OTP</span>
                    <span id="send-otp-loader" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                  </button>
                </div>
              </form>
              <div class="text-center pt-20 text-danger" id="login-error-message"></div>
              <div class="th-login-form-footer text-center pt-20">
                <p>Are you new? <a class="th-underline th-bold" href="/signup">Create an account</a>
                </p>
              </div>
              <div class="text-center my-3">
                <span class="text-muted font-weight-600">Or,</span>
              </div>
              <div class="d-grid gap-2">
                <form id="google-login-form" method="POST" action="/auth/google" style="display: contents;">
                  <input type="hidden" name="pinboard" id="google-login-pinboard-value" value="">
                  <button type="submit" id="google-login-link" class="btn th-btn-gray text-capitalize border d-flex align-items-center justify-content-center gap-2 w-100">
                  <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                    <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303C33.653 32.657 29.203 36 24 36c-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.27 4 24 4C12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" />
                    <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.27 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" />
                    <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.143 35.091 26.715 36 24 36c-5.182 0-9.617-3.316-11.283-7.946l-6.523 5.025C9.505 39.556 16.227 44 24 44z" />
                    <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303c-.793 2.239-2.231 4.166-4.084 5.571l.003-.002 6.19 5.238C37.007 38.469 44 33 44 24c0-1.341-.138-2.65-.389-3.917z" />
                  </svg>
                  <span>Login with Google</span>
                </button>
                </form>
                <form id="microsoft-login-form" method="POST" action="/auth/microsoft" style="display: contents;">
                  <input type="hidden" name="pinboard" id="microsoft-login-pinboard-value" value="">
                  <button type="submit" id="microsoft-login-link" class="btn th-btn-gray text-capitalize border d-flex align-items-center justify-content-center gap-2 w-100">
                  <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <rect x="1" y="1" width="10" height="10" fill="#F25022" />
                    <rect x="13" y="1" width="10" height="10" fill="#7FBA00" />
                    <rect x="1" y="13" width="10" height="10" fill="#00A4EF" />
                    <rect x="13" y="13" width="10" height="10" fill="#FFB900" />
                  </svg>
                  <span>Login with Microsoft</span>
                </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>


    </div>

    <div class="modal fade backdrop-static" id="verifyEmailModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="false" style="position:fixed; inset:0; background-color: rgba(0,0,0,0.5); z-index:1040;">

      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modelBorderRadius">
          <div class="modal-header">
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">

            <form id="verify-email-form" class="guest-signup-form" action="/login/verify-email" method="POST">
              <input type="hidden" name="nonce" value="{{ nonce|default('') }}">
              <input type="hidden" name="email" id="verify-email-value" value="{{ data.email|default('') }}">
              <input type="hidden" name="otp" id="verify-email-otp-value" value="">
              <input type="hidden" name="pinboard" id="verify-email-pinboard-value" value="">
              <div class="text-center py-10 mb-20">
                <h6>Verify it's you</h6>
                <p>
                  We've sent a verification code to
                  <strong id="verify-email-display"></strong>.
                  <br>
                  Please enter the code below to verify your email.
                </p>
              </div>

              <!-- OTP BOXES -->
              <div class="otp-wrapper mb-20">
                <input type="text" maxlength="1" class="otp-input" data-otp-index="0" inputmode="numeric" autocomplete="one-time-code">
                <input type="text" maxlength="1" class="otp-input" data-otp-index="1" inputmode="numeric">
                <input type="text" maxlength="1" class="otp-input" data-otp-index="2" inputmode="numeric">
                <input type="text" maxlength="1" class="otp-input" data-otp-index="3" inputmode="numeric">
                <input type="text" maxlength="1" class="otp-input" data-otp-index="4" inputmode="numeric">
                <input type="text" maxlength="1" class="otp-input" data-otp-index="5" inputmode="numeric">
              </div>

              <!-- PRIMARY BUTTON -->
              <button type="submit" class="th-btn-primary text-capitalize w-100 mt-15" id="verify-email-button">
                Verify & Continue
              </button>

              <!-- OTP TIMER TEXT -->
              <div class="text-center mt-15">
                <span id="otp-timer-text">
                  Resend in 00:00
                </span>
              </div>

              <!-- RESEND LINK -->
              <div class="text-center mt-15">
                <small>
                  Didn't receive the code?
                  <a href="#" class="resend-link" id="resend-otp-button">
                  <span class="spinner-border spinner-border-sm ms-2 d-none" id="resend-otp-loader" role="status" aria-hidden="true"></span>
                    Resend OTP
                  </a>
                </small>
              </div>
            </form>


          </div>
        </div>
      </div>

    </div>

  </section>
  <!--============================== End Login Page ==============================-->



