    <script>
      var countdownInterval = null;

      function startOTPTimer(durationInSeconds) {
        var timerText = document.getElementById('otp-timer-text');
        var resendButton = document.getElementById('resend-otp-button');
        var resendLoader = document.getElementById('resend-otp-loader');

        if (countdownInterval) {
          clearInterval(countdownInterval);
        }

        var timeRemaining = durationInSeconds;

      
        if (resendButton) {
          resendButton.style.pointerEvents = 'none';
          resendButton.style.color = 'gray';
          resendButton.classList.add('disabled');
          resendButton.setAttribute('aria-disabled', 'true');
        }
        
        if (resendLoader) {
          resendLoader.classList.add('d-none');
        }

        countdownInterval = setInterval(function () {
          var minutes = Math.floor(timeRemaining / 60);
          var seconds = timeRemaining % 60;

          minutes = minutes < 10 ? '0' + minutes : minutes;
          seconds = seconds < 10 ? '0' + seconds : seconds;

          if (timerText) {
            timerText.textContent = 'Resend in ' + minutes + ':' + seconds;
          }

          if (timeRemaining <= 0) {
            clearInterval(countdownInterval);
            if (timerText) {
              timerText.textContent = '';
            }
            if (resendButton) {
              resendButton.style.pointerEvents = 'auto';
              resendButton.style.color = ''; 
              resendButton.classList.remove('disabled');
              resendButton.removeAttribute('aria-disabled');
            }
          }

          timeRemaining--;
        }, 1000);
      }

      function showOtpModal(modal, attempt) {
        if (!modal) return;

        if (window.bootstrap && window.bootstrap.Modal) {
          var verifyModal = window.bootstrap.Modal.getOrCreateInstance(modal);
          verifyModal.show();
          return;
        }

        if ((attempt || 0) < 8) {
          window.setTimeout(function () {
            showOtpModal(modal, (attempt || 0) + 1);
          }, 120);
          return;
        }

        modal.classList.add('show');
        modal.style.display = 'block';
        modal.removeAttribute('aria-hidden');
        document.body.classList.add('modal-open');
      }

      function getLocalPinboardPayload() {
        var pinboardParsed = null;
        try {
          pinboardParsed = JSON.parse(localStorage.getItem('pinboard') || 'null');
        } catch (jsonError) {
          pinboardParsed = null;
        }

        var pinboardItems = Array.isArray(pinboardParsed && pinboardParsed.pinboard_items)
          ? pinboardParsed.pinboard_items
          : [];

        return {
          job_title: (pinboardParsed && pinboardParsed.pinboard_name) || 'Project Name',
          pinboard_description: (pinboardParsed && pinboardParsed.pinboard_description) || '',
          form_type: 'web_login',
          pinboard_items: pinboardItems
        };
      }

      function initLoginPage() {
        var otpRequested = {{ otp_requested|default(false) ? 'true' : 'false' }};
        var modal = document.getElementById('verifyEmailModal');
        var verifyEmailDisplay = document.getElementById('verify-email-display');
        var verifyEmailValue = document.getElementById('verify-email-value');
        var otpHiddenInput = document.getElementById('verify-email-otp-value');
        var verifyForm = document.getElementById('verify-email-form');
        var verifyButton = document.getElementById('verify-email-button');
        var loginErrorMessage = document.getElementById('login-error-message');
        var pinboardHiddenInput = document.getElementById('verify-email-pinboard-value');
        var otpInputs = Array.prototype.slice.call(document.querySelectorAll('.otp-input'));
        var emailInput = document.getElementById('email');
        var loginForm = document.getElementById('login-form');
        var sendOtpButton = document.getElementById('send-otp-button');
        var sendOtpText = document.getElementById('send-otp-text');
        var sendOtpLoader = document.getElementById('send-otp-loader');
        
        var params = new URLSearchParams(window.location.search || '');
        var queryEmail = (params.get('email') || '').trim().toLowerCase();
        var queryOtpRequested = (params.get('otp_requested') || '').trim();
        var queryMessage = (params.get('message') || '').trim();
        var inputEmail = (emailInput && emailInput.value ? emailInput.value : '').trim().toLowerCase();
        
        var shouldAutoOpenModal = (
          otpRequested === true &&
          queryOtpRequested === '1' &&
          queryMessage === 'OTP sent successfully.' &&
          queryEmail !== '' &&
          inputEmail !== '' &&
          queryEmail === inputEmail
        );

        if (verifyEmailDisplay && emailInput) {
          verifyEmailDisplay.textContent = emailInput.value || 'email@example.com';
        }

        if (verifyEmailValue && emailInput) {
          verifyEmailValue.value = emailInput.value || '';
        }

        if (loginForm && sendOtpButton) {
          loginForm.addEventListener('submit', function () {
            sendOtpButton.disabled = true;
            if (sendOtpText) {
              sendOtpText.textContent = 'Sending...';
            }
            if (sendOtpLoader) {
              sendOtpLoader.classList.remove('d-none');
            }
          });
        }

        if (shouldAutoOpenModal) {
          showOtpModal(modal, 0);
          startOTPTimer(120);
        }

        otpInputs.forEach(function (input, idx) {
          input.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 1);
            if (this.value && otpInputs[idx + 1]) {
              otpInputs[idx + 1].focus();
            }
          });

          input.addEventListener('keydown', function (event) {
            if (event.key === 'Backspace' && !this.value && otpInputs[idx - 1]) {
              otpInputs[idx - 1].focus();
            }
          });

          input.addEventListener('paste', function (event) {
            event.preventDefault();
            var clipboardData = (event.clipboardData || window.clipboardData);
            var raw = clipboardData ? clipboardData.getData('text') : '';
            var digits = (raw || '').replace(/\D/g, '').slice(0, otpInputs.length);
            if (!digits) return;

            digits.split('').forEach(function (digit, index) {
              if (otpInputs[index]) {
                otpInputs[index].value = digit;
              }
            });

            var firstEmpty = otpInputs.find(function (el) { return !el.value; });
            (firstEmpty || otpInputs[otpInputs.length - 1]).focus();
          });
        });


        if (verifyForm) {
          verifyForm.addEventListener('submit', function (event) {
            event.preventDefault();
            var otp = otpInputs.map(function (el) { return el.value || ''; }).join('');
            
            if (otp.length !== 6) {
              if (loginErrorMessage) {
                loginErrorMessage.textContent = 'Please enter the 6-digit OTP code.';
              }
              return;
            }

            if (!emailInput || !emailInput.value) {
              if (loginErrorMessage) {
                loginErrorMessage.textContent = 'Email is missing.';
              }
              return;
            }

            if (verifyButton) {
              verifyButton.disabled = true;
              verifyButton.textContent = 'Verifying...';
            }

            if (otpHiddenInput) {
              otpHiddenInput.value = otp;
            }

            if (pinboardHiddenInput) {
              pinboardHiddenInput.value = JSON.stringify(getLocalPinboardPayload());
            }

            verifyForm.submit();
          });
        }

        var googleLoginForm = document.getElementById('google-login-form');
        var googleLoginPinboardInput = document.getElementById('google-login-pinboard-value');
        if (googleLoginForm && googleLoginPinboardInput) {
          googleLoginForm.addEventListener('submit', function () {
            googleLoginPinboardInput.value = JSON.stringify(getLocalPinboardPayload());
          });
        }

        var microsoftLoginForm = document.getElementById('microsoft-login-form');
        var microsoftLoginPinboardInput = document.getElementById('microsoft-login-pinboard-value');
        if (microsoftLoginForm && microsoftLoginPinboardInput) {
          microsoftLoginForm.addEventListener('submit', function () {
            microsoftLoginPinboardInput.value = JSON.stringify(getLocalPinboardPayload());
          });
        }

        var resendButton = document.getElementById('resend-otp-button');
        if (resendButton) {
          resendButton.addEventListener('click', async (event) => {
            event.preventDefault();
            
            if (resendButton.classList.contains('disabled')) {
              return;
            }

            const resendLoader = document.getElementById('resend-otp-loader');
            const emailInputEl = document.getElementById('email');
            const email = emailInputEl ? emailInputEl.value : '';
            if (!email) return;

            resendButton.style.pointerEvents = 'none';
            resendButton.setAttribute('aria-disabled', 'true');
            resendButton.classList.add('disabled');
            if (resendLoader) {
              resendLoader.classList.remove('d-none');
            }

            try {
              const res = await fetch('/api/send-email-verification', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: email, subject: 'Login Verification Code with Krost' }),
              });
              const data = await res.json();
              console.log("data", data);
              
              if (data) {
                startOTPTimer(120);  
              } else {
                if (resendLoader) resendLoader.classList.add('d-none');
                resendButton.style.pointerEvents = '';
                resendButton.removeAttribute('aria-disabled');
                resendButton.classList.remove('disabled');
              }
            } catch (error) {
              console.error("Error resending OTP:", error);
              if (resendLoader) resendLoader.classList.add('d-none');
              resendButton.style.pointerEvents = '';
              resendButton.removeAttribute('aria-disabled');
              resendButton.classList.remove('disabled');
            }
          });
        }
      }

      if (document.readyState === 'complete') {
        initLoginPage();
      } else {
        window.addEventListener('load', initLoginPage);
      }
    </script>

