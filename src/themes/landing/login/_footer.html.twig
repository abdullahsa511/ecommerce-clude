{% set subscription_email = email|default(data.email|default('')) %}
{% set email_error = errors.email is defined and errors.email|default('') != '' %}
{% set has_form_errors = errors is defined and errors|length > 0 %}
{% set has_success = success is defined and success|default('') != '' %}
<!--============================== Footer ==============================-->
<section id="footer-section-container" class="th-footer bg-gray th-footer-section-py" title="footer" data-v-save-global="index.html,.footer-1" data-v-component-footer>
  {% if is_admin|default(false) %}
  <div data-v-footer-edit-link-container class="d-flex justify-content-end pr-40 align-items-center position-absolute th-component-edit-link" style="right: 40px">
    <i class="fa-solid fa-pencil pr-5 th-pr-5" style="font-size: .8rem"></i>
    <a data-v-footer-edit-link href="{{ footer.component_link|default('') }}" target="_blank">Edit</a>
  </div>
  {% endif %}
  <div class="container th-container" data-v-slug="main-footer">
    <div class="row component-footer">
      <div class="col-lg-8 border-right-dark border-right-md-0">
        <h4 class="text-weight-700 th-footer-title th-title-mb-15">Contact Us</h4>
        <div class="footer-left-content">
          <div class="text-weight-600 pt-10">
            <div class="d-flex align-items-center">
              <i class="fa-solid fa-envelope pr-5 th-pr-5"></i>
              <p data-v-footer-contact_email>
                <a href="mailto:{{ footer.contact_email|default('') }}">{{ footer.contact_email|default('') }}</a>
              </p>
            </div>
            <div class="d-flex align-items-center">
              <i class="fa-solid fa-phone pr-5 th-pr-5"></i>
              <p data-v-footer-contact_phone>
                <a href="tel:1800157678" class="footer-phone-link">{{ footer.contact_phone|default('') }}</a>
              </p>
            </div>
          </div>

          <div class="d-grid grid-col-3">
            <div class="th-showroom-address">
              <p class="th-footer-heading th-footer-title-mb" data-v-footer-sydney_office_name>{{ footer.sydney_office_name|default('') }}</p>
              <p class="th-address-line" data-v-footer-sydney_office_address>{{ footer.sydney_office_address|default('')|raw }}</p>
              <div class="d-flex align-items-center text-weight-600 pt-10">
                <i class="fa-solid fa-phone pr-5 th-pr-5"></i>
                <p data-v-footer-sydney_office_phone>
                  <a href="{{ phone_tel_href(footer.sydney_office_phone|default('')) }}" class="footer-phone-link">{{ footer.sydney_office_phone|default('') }}</a>
                </p>
              </div>
              <p class="th-opening-hours" data-v-footer-sydney_office_hours>{{ footer.sydney_office_hours|default('') }}</p>
            </div>

            <div class="th-showroom-address">
              <p class="text-weight-600 mb-15 th-footer-heading th-footer-title-mb" data-v-footer-melbourne_office_name>{{ footer.melbourne_office_name|default('') }}</p>
              <p class="th-address-line" data-v-footer-melbourne_office_address>{{ footer.melbourne_office_address|default('')|raw }}</p>
              <div class="d-flex align-items-center text-weight-600 pt-10">
                <i class="fa-solid fa-phone pr-5 th-pr-5"></i>
                <p data-v-footer-melbourne_office_phone>
                  <a href="{{ phone_tel_href(footer.melbourne_office_phone|default('')) }}" class="footer-phone-link">{{ footer.melbourne_office_phone|default('') }}</a>
                </p>
              </div>
              <p class="th-opening-hours" data-v-footer-melbourne_office_hours>{{ footer.melbourne_office_hours|default('') }}</p>
            </div>

            <div class="th-showroom-address">
              <p class="text-weight-600 mb-15 th-footer-heading th-footer-title-mb" data-v-footer-brisbane_office_name>{{ footer.brisbane_office_name|default('') }}</p>
              <p class="th-address-line" data-v-footer-brisbane_office_address>{{ footer.brisbane_office_address|default('')|raw }}</p>
              <div class="d-flex align-items-center text-weight-600 pt-10">
                <i class="fa-solid fa-phone pr-5 th-pr-5"></i>
                <p data-v-footer-brisbane_office_phone>
                  <a href="{{ phone_tel_href(footer.brisbane_office_phone|default('')) }}" class="footer-phone-link">{{ footer.brisbane_office_phone|default('') }}</a>
                </p>
              </div>
              <p class="th-opening-hours" data-v-footer-brisbane_office_hours>{{ footer.brisbane_office_hours|default('') }}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-4 d-flex flex-column">
        <div class="th-subscription pl-20 th-pl-20 pl-md-0">
          <div class="th-subscription-heading">
            <div class="th-subscription-details">
              <h4 class="text-weight-700 th-footer-title" data-v-footer-subscription_title>{{ footer.subscription_title|default('') }}</h4>
              <div class="th-description description" data-v-footer-subscription_description>{{ footer.subscription_description|default('') }}</div>
            </div>
          </div>
          <form action="/#subscription-form" method="POST" id="subscription-form" class="th-form needs-validation{% if has_form_errors %} was-validated invalid{% elseif has_success %} was-validated valid{% endif %}">
            <input type="hidden" name="nonce" id="subscription-form-nonce" value="{{ nonce|default('') }}" data-v-nonce>
            <div class="th-subscription-form" id="subscription-form-container">
              <label class="pr-10">
                <input type="email" class="form-control{% if email_error %} is-invalid{% endif %}" name="email" id="subscriptionEmail" value="{{ subscription_email }}" placeholder="{{ footer.subscription_placeholder|default('Enter your email') }}" data-v-footer-subscription_placeholder />
                {% if email_error %}
                <div class="invalid-feedback" id="email-feedback">{{ errors.email }}</div>
                {% else %}
                <div class="invalid-feedback" id="email-feedback"></div>
                {% endif %}
                <div class="valid-feedback" id="success-feedback">{% if has_success %}{{ success }}{% endif %}</div>
              </label>
              <div class="link">
                <button id="subscription-form-button" type="submit" class="link-text pr-5" data-v-footer-subscription_button_text>{{ footer.subscription_button_text|default('Subscribe') }}</button>
              </div>
            </div>
          </form>
        </div>
        <div class="th-footer-navigation">
          <ul>
            <li class="">
              <span class="link">
                <a href="{{ footer.footer_navigation_our_store_url|default('/about') }}" data-v-footer-footer_navigation_our_store>{{ footer.footer_navigation_our_store|default('About') }}</a>
              </span>
            </li>
            <li class="class">
              <span class="link class">
                <a href="{{ footer.footer_navigation_catalogue_url|default('/catalogue') }}" data-v-footer-footer_navigation_catalogue>{{ footer.footer_navigation_catalogue|default('Catalogue') }}</a>
              </span>
            </li>
            <li class="class">
              <span class="link class">
                <a href="{{ footer.footer_navigation_contact_us_url|default('/contact-us') }}" data-v-footer-footer_navigation_contact_us>{{ footer.footer_navigation_contact_us|default('Contact Us') }}</a>
              </span>
            </li>
            <li class="class">
              <span class="link class">
                <a href="{{ footer.footer_navigation_faqs_url|default('/faqs') }}" data-v-footer-footer_navigation_faqs>{{ footer.footer_navigation_faqs|default('FAQs') }}</a>
              </span>
            </li>
            <li class="border-right-0">
              <span class="link border-right-0">
                <a href="{{ footer.footer_navigation_resources_url|default('/resources') }}" data-v-footer-footer_navigation_resources>{{ footer.footer_navigation_resources|default('Resources') }}</a>
              </span>
            </li>
          </ul>
        </div>

        <div class="th-footer-follow th-pt-30 mt-auto th-pl-20 pl-md-0">
          <p class="text-weight-600 th-pb-10">Follow Us:</p>
          <div class="social-media">
            <ul class="social-media-list" data-v-footer-socila-media-list>
              {% for social_media in footer.social_media|default([]) %}
              <li class="social-media-item" data-v-footer-socila-media-item>
                <span class="link">
                  <a href="{{ social_media.url|default('') }}" target="_blank" data-v-url aria-label="{{ social_media.platform|default('') }}">
                    <i class="{{ social_media.icon|default('') }}" data-v-icon></i>
                  </a>
                </span>
              </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="th-footer-copyright mt-30">
    <div class="container th-container">
      <div class="d-flex flex-column flex-md-row th-footer-copyright-content">
        <div class="text-muted flex-grow-1">
          <a class="btn-link text-muted" href="{{ footer.copyright_privacy_url|default('/privacy-policy') }}" target="_blank" data-v-footer-copyright_privacy_url>Terms & Privacy Policy</a>
        </div>
        <div class="text-muted copyright-text-right">
          &copy;
          <span class="text-muted" data-v-footer-copyright_powered_by_url aria-label="KROST">{{ footer.copyright_powered_by_text|default('Krost Business Furniture') }}</span>
          <span data-v-footer-copyright_year>{{ footer.copyright_year|default("now"|date("Y")) }}</span>
        </div>
      </div>
    </div>
  </div>
</section>
<!--============================== End Footer ==============================-->

<style>
  .footer-logo-container {
    display: flex;
    align-items: right;
    justify-content: right;
    margin-top: -65px;
  }

  .footer-logo {
    top: 239px;
    left: 1396px;
    width: 74px;
    height: 61px;
  }
  .th-footer-navigation ul {
    display: flex;
    flex-wrap: nowrap;      /* Keep all items on one line */
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 5px;              /* Space between items */
}

.th-footer-navigation li {
    white-space: nowrap;    /* Prevent text from wrapping */
}

.th-footer-navigation a {
    display: inline-block;
    white-space: nowrap;
}
</style>
